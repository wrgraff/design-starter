# ────────────────────────────────────────────────────────────────
# design-starter — environment variables
# ────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values.
# Never commit `.env` — only `.env.example` is tracked.
#
# Naming rules (SvelteKit convention):
#   PUBLIC_*  — exposed to the browser bundle. Safe for non-secret values.
#   (others)  — server-only, never exposed to the browser.
# ────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────
# Get these from the Supabase Dashboard → Project Settings → API.

# Project URL (safe to expose).
PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"

# Anonymous public key — used by the browser, scoped by RLS (safe to expose).
PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# Service-role key — SERVER ONLY. Bypasses RLS. Never expose to the browser.
# Required for pnpm db:seed. Get from Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"


# ── Optional auth module ─────────────────────────────────────────
# Used only if the auth module is enabled (see docs/AUTH.md).

# Comma-separated emails granted admin role at signin.
# ADMIN_EMAILS="you@example.com"


# ── App ──────────────────────────────────────────────────────────

# Public app URL — used by PWA, OAuth redirects, og:url, etc.
PUBLIC_APP_URL="http://localhost:5173"
